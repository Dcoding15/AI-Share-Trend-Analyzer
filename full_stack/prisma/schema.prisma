model WatchList {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  symbol String @db.VarChar(10)
  name   String @db.VarChar(100)
  sector String @db.VarChar(50)

  createdAt DateTime @default(now())

  @@unique([userId, symbol])
}

enum Sentiment {
  Bullish
  Bearish
  Neutral
}

model SharePrediction{
  id String @id @default(cuid())

  symbol String
  currentPrice Float
  predictedPrice Float
  rangeLow Float
  rangeHigh Float
  confidence Float
  horizon String
  trend Sentiment
  signalStrength String
  summary String @db.Text
  rsi Float
  macd Float
  macdSignal Float
  ema50 Float
  ema200 Float
  bbUpper Float
  bbMid Float
  bbLower Float
  stochK Float
  stochD Float
  atr Float
  volumeRatio Float
  createdAt DateTime @default(now())

  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([symbol, createdAt])
  @@index([userId])
}